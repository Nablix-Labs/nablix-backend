NABLIX_APP_NAME=Nablix AI Math Tutor API
NABLIX_TUTOR_ENGINE_URL=http://localhost:8001
NABLIX_VOICE_SERVICE_URL=http://localhost:8004
NABLIX_STUDENT_MODEL_URL=
NABLIX_STUDENT_MODEL_TOPIC_IDS={}
NABLIX_USE_MOCK_STUDENT_MODEL=false
NABLIX_MAIN_BACKEND_URL=http://127.0.0.1:8000
VOICE_STT_PROVIDER=deepgram
VOICE_TTS_PROVIDER=openai
VOICE_TTS_VOICE=shimmer
VOICE_TTS_FORMAT=mp3
NABLIX_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
NABLIX_OPENAI_API_KEY=
NABLIX_EMBEDDING_MODEL=text-embedding-3-small
NABLIX_OPENAI_PROMPT_CACHE_KEY_ENABLED=true
NABLIX_OCR_PROVIDER=openai
NABLIX_MATHPIX_APP_ID=
NABLIX_MATHPIX_APP_KEY=
NABLIX_USE_MOCK_TUTOR=true
NABLIX_USE_MOCK_VOICE=true
NABLIX_USE_MOCK_VISION=true
NABLIX_ADAPTER_REQUEST_TIMEOUT_SECONDS=20
NABLIX_ADAPTER_REQUEST_RETRY_COUNT=2
NABLIX_MAX_TEXT_INPUT_LENGTH=500
# Aditya's RAG service (app/services/rag) reads the unprefixed pair.
QDRANT_URL=
QDRANT_API_KEY=
# The tutoring backend's question bank and RAG endpoint read the NABLIX_ pair.
NABLIX_QDRANT_URL=
NABLIX_QDRANT_API_KEY=
NABLIX_QDRANT_COLLECTION=math_tutor_content
NABLIX_QDRANT_CONCEPT_ID_MAP={"ALG_LINEAR_ONE_STEP":"ALG_LINEAR_ONE_STEP_ADDITION"}
DEEPGRAM_API_KEY=
